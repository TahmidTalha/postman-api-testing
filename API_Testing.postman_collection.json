    {
      "name": "update Booking",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "\r",
              "// FIRST NAME (reuse if exists)\r",
              "let firstName = pm.environment.get(\"firstName\");\r",
              "if (!firstName) {\r",
              "    firstName = pm.variables.replaceIn('{{$randomFirstName}}');\r",
              "}\r",
              "pm.environment.set(\"firstName\", firstName);\r",
              "\r",
              "// LAST NAME\r",
              "let lastName = pm.environment.get(\"lastName\");\r",
              "if (!lastName) {\r",
              "    lastName = pm.variables.replaceIn('{{$randomLastName}}');\r",
              "}\r",
              "pm.environment.set(\"lastName\", lastName);\r",
              "\r",
              "// TOTAL PRICE\r",
              "let totalprice = pm.environment.get(\"totalPrice\");\r",
              "if (!totalprice) {\r",
              "    totalprice = Math.floor(Math.random() * 500) + 50;\r",
              "}\r",
              "pm.environment.set(\"totalPrice\", totalprice);\r",
              "\r",
              "// DEPOSIT\r",
              "let deposit = pm.environment.get(\"deposit\");\r",
              "if (deposit === null || deposit === undefined) {\r",
              "    deposit = pm.variables.replaceIn('{{$randomBoolean}}');\r",
              "}\r",
              "pm.environment.set(\"deposit\", deposit);\r",
              "\r",
              "// DATE FORMAT FUNCTION (UNCHANGED)\r",
              "let d = new Date();\r",
              "\r",
              "let format = date =>\r",
              "  date.getFullYear() + '-' +\r",
              "  String(date.getMonth() + 1).padStart(2, '0') + '-' +\r",
              "  String(date.getDate()).padStart(2, '0');\r",
              "\r",
              "// CHECK-IN (reuse if exists)\r",
              "let checkin = pm.environment.get(\"checkin\");\r",
              "if (!checkin) {\r",
              "    checkin = format(d);\r",
              "}\r",
              "pm.environment.set(\"checkin\", checkin);\r",
              "\r",
              "// CHECK-OUT (based on checkin OR new)\r",
              "let checkout = pm.environment.get(\"checkout\");\r",
              "\r",
              "if (!checkout) {\r",
              "    d.setDate(d.getDate() + 2);\r",
              "    checkout = format(d);\r",
              "}\r",
              "\r",
              "pm.environment.set(\"checkout\", checkout);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// STATUS CODE\r",
              "pm.test(\"Verify status code is 200\", function () {\r",
              "    pm.expect(pm.response.code).to.eql(200);\r",
              "});\r",
              "\r",
              "// RESPONSE TIME\r",
              "pm.test(\"Verify response time is less than 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "// PARSE RESPONSE SAFELY\r",
              "let responseBody = pm.response.json();\r",
              "\r",
              "// FIRST NAME\r",
              "pm.test(\"Verify First Name\", function () {\r",
              "    pm.expect(responseBody.firstname)\r",
              "        .to.eql(pm.environment.get(\"firstName\"));\r",
              "});\r",
              "\r",
              "// LAST NAME\r",

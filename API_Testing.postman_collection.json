    {
      "name": "Create Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// PARSE RESPONSE ONCE\r",
              "var responseBody = pm.response.json();\r",
              "\r",
              "// STORE BOOKING ID\r",
              "pm.environment.set(\"id\", responseBody.bookingid);\r",
              "\r",
              "// ASSERT STATUS CODE\r",
              "pm.test(\"Verify the status code is 200 or 201\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
              "});\r",
              "\r",
              "// RESPONSE TIME\r",
              "pm.test(\"Verify response time is less than 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "// FIRST NAME\r",
              "pm.test(\"Verify First Name\", function () {\r",
              "    pm.expect(responseBody.booking.firstname)\r",
              "        .to.eql(pm.environment.get(\"firstName\"));\r",
              "});\r",
              "\r",
              "// LAST NAME\r",
              "pm.test(\"Verify Last Name\", function () {\r",
              "    pm.expect(responseBody.booking.lastname)\r",
              "        .to.eql(pm.environment.get(\"lastName\"));\r",
              "});\r",
              "\r",
              "// TOTAL PRICE\r",
              "pm.test(\"Verify Total Price\", function () {\r",
              "    pm.expect(responseBody.booking.totalprice)\r",
              "        .to.eql(parseInt(pm.environment.get(\"totalPrice\")));\r",
              "});\r",
              "\r",
              "// DEPOSIT PAID\r",
              "pm.test(\"Verify Deposit Paid\", function () {\r",
              "    pm.expect(responseBody.booking.depositpaid.toString())\r",
              "        .to.eql(pm.environment.get(\"deposit\"));\r",
              "});\r",
              "\r",
              "// CHECKIN\r",
              "pm.test(\"Verify Check-in Date\", function () {\r",
              "    pm.expect(responseBody.booking.bookingdates.checkin)\r",
              "        .to.eql(pm.environment.get(\"checkin\"));\r",
              "});\r",
              "\r",
              "// CHECKOUT\r",
              "pm.test(\"Verify Check-out Date\", function () {\r",
              "    pm.expect(responseBody.booking.bookingdates.checkout)\r",
              "        .to.eql(pm.environment.get(\"checkout\"));\r",
              "});\r",
              "\r",
              "// VALID JSON\r",
              "pm.test(\"Response is valid JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "\r",
              "// FIRST NAME\r",
              "let firstName = pm.variables.replaceIn('{{$randomFirstName}}');\r",
              "pm.environment.set(\"firstName\", firstName);\r",
              "console.log(\"Generated First Name:\", firstName);\r",
              "\r",
              "// LAST NAME\r",
              "let lastName = pm.variables.replaceIn('{{$randomLastName}}');\r",
              "pm.environment.set(\"lastName\", lastName);\r",
              "console.log(\"Generated Last Name:\", lastName);\r",
              "\r",
              "// TOTAL PRICE (FIXED RANDOM GENERATION)\r",
              "let totalPrice = Math.floor(Math.random() * 500) + 50; // 50–550\r",
              "pm.environment.set(\"totalPrice\", totalPrice);\r",
              "console.log(\"Total Price:\", totalPrice);\r",
              "\r",
              "// DEPOSIT PAID\r",
              "let deposit = pm.variables.replaceIn('{{$randomBoolean}}');\r",
              "pm.environment.set(\"deposit\", deposit);\r",
              "console.log(\"Deposit:\", deposit);\r",
              "\r",
              "// DATE FORMAT FUNCTION\r",
              "function formatDate(date) {\r",
              "    let year = date.getFullYear();\r",
              "    let month = String(date.getMonth() + 1).padStart(2, '0');\r",
              "    let day = String(date.getDate()).padStart(2, '0');\r",
              "    return `${year}-${month}-${day}`;\r",
              "}\r",
              "\r",
              "// CHECK-IN DATE (1–30 days ahead)\r",
              "let today = new Date();\r",
              "let checkinDate = new Date();\r",
              "let randomDaysToAdd = Math.floor(Math.random() * 30) + 1;\r",
              "checkinDate.setDate(today.getDate() + randomDaysToAdd);\r",
              "\r",
              "// CHECK-OUT DATE (1–10 days stay)\r",
              "let checkoutDate = new Date(checkinDate);\r",
              "let randomStay = Math.floor(Math.random() * 10) + 1;\r",
              "checkoutDate.setDate(checkinDate.getDate() + randomStay);\r",
              "\r",
              "// FORMAT\r",
              "let checkin = formatDate(checkinDate);\r",
              "let checkout = formatDate(checkoutDate);\r",
              "\r",
              "// STORE\r",
              "pm.environment.set(\"checkin\", checkin);\r",
              "pm.environment.set(\"checkout\", checkout);\r",
              "\r",
              "console.log(\"Check-in:\", checkin);\r",
              "console.log(\"Check-out:\", checkout);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
